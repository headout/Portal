# Portal config — copy to .env and fill in. Used by api/ and worker/ (and passed to the
# RunPod endpoint env for the worker).

# --- RunPod Serverless (used by api/) ---
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# --- Object storage: Cloudflare R2 or AWS S3 (used by api/ + worker/) ---
# For AWS S3, leave S3_ENDPOINT blank and set S3_REGION to your region.
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=portal
S3_KEY=
S3_SECRET=
S3_REGION=auto
# Optional public base for returned splat URLs (R2 public bucket / CDN). Blank = presigned GET.
S3_PUBLIC_BASE=

# --- Worker tuning (optional; the worker image sets sensible defaults) ---
# GSPLAT_TRAINER, GLOMAP_BIN, COLMAP_BIN, FFMPEG_BIN are set in worker/Dockerfile.

# --- Local dev object storage (infra/docker-compose.dev.yaml MinIO) ---
# S3_ENDPOINT=http://localhost:9000
# S3_KEY=minioadmin
# S3_SECRET=minioadmin
# S3_REGION=us-east-1
